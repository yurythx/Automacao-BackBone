# Shared
POSTGRES_PASSWORD=backbone_pg_pass_2026
REDIS_PASSWORD=backbone_redis_pass_2026
TZ=America/Sao_Paulo

# Evolution API
EVOLUTION_IMAGE=evoapicloud/evolution-api:v2.3.7
EVOLUTION_CONTAINER=evolution_api
EVOLUTION_PORT=8081
SERVER_URL=https://evolution.projetoravenna.cloud
DEL_INSTANCE=false
DEL_TEMP_INSTANCES=false
PROVIDER_ENABLED=false
PROVIDER_HOST=127.0.0.1
PROVIDER_PORT=8080
PROVIDER_PREFIX=/
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://postgres:${POSTGRES_PASSWORD}@postgres_evolution:5432/evolution_production
DATABASE_CONNECTION_CLIENT_NAME=evolution
AUTHENTICATION_API_KEY=evol_api_key_2026_backbone
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true
LANGUAGE=pt
TELEMETRY=false

CONFIG_SESSION_PHONE_CLIENT=Chrome
CONFIG_SESSION_PHONE_NAME=Chrome
QRCODE_LIMIT=30
TYPEBOT_ENABLED=false
TYPEBOT_API_VERSION=latest
CHATWOOT_ENABLED=true
CHATWOOT_MESSAGE_READ=true
CHATWOOT_IMPORT_DATABASE_CONNECTION_URI=postgresql://postgres:${POSTGRES_PASSWORD}@postgres_evolution:5432/evolution_production
CHATWOOT_IMPORT_PLACEHOLDER_MEDIA_MESSAGE=true
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://:${REDIS_PASSWORD}@redis_evolution:6379
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=true
CACHE_LOCAL_ENABLED=false
RESTART_POLICY=always

# n8n
N8N_IMAGE=n8nio/n8n:2.16.0
N8N_ENCRYPTION_KEY=n8n_secret_key_2026_backbone
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=backbone_n8n_pass_2026

# ── Object Storage (MinIO) ───────────────────────────────────
USE_S3=True
# Credenciais de ADMIN do MinIO (Root)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=backbone_minio_root_2026

# Credenciais de acesso S3 (Geralmente as mesmas do Root no MinIO)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=backbone_minio_root_2026
AWS_STORAGE_BUCKET_NAME=backbone-media
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_REGION_NAME=us-east-1

# GLPI Database
MYSQL_ROOT_PASSWORD=glpi_root_admin
MYSQL_DATABASE=glpi_db
MYSQL_USER=glpi_user
MYSQL_PASSWORD=glpi_pass_2026

# Zabbix Database
ZABBIX_POSTGRES_USER=zabbix
ZABBIX_POSTGRES_PASSWORD=zabbix_pass_2026
ZABBIX_POSTGRES_DB=zabbix

# GLPI API
GLPI_APP_TOKEN=defina_token_app
GLPI_USER_TOKEN=defina_token_usuario

# Zabbix API
ZABBIX_API_URL=http://zabbix-web:8080/api_jsonrpc.php
ZABBIX_USER=admin
ZABBIX_PASSWORD=admin_pass_2026



