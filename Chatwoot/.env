# Chatwoot Environment Variables

# Postgres
POSTGRES_HOST=chatwoot_db
POSTGRES_PORT=5432
POSTGRES_DB=chatwoot_production
POSTGRES_DATABASE=chatwoot_production
POSTGRES_USER=postgres
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}

# Redis
REDIS_URL=redis://:${REDIS_PASSWORD}@chatwoot_redis:6379
REDIS_PASSWORD=${REDIS_PASSWORD}

# Rails
# Secret Key Base - Updated for security
SECRET_KEY_BASE=backbone_chatwoot_secret_2026_rails_key
FRONTEND_URL=https://atendimento.projetoravenna.cloud
ACTIVE_STORAGE_HOST=https://atendimento.projetoravenna.cloud

# Storage (Using Internal MinIO)
ACTIVE_STORAGE_SERVICE=s3_compatible
S3_BUCKET_NAME=${AWS_STORAGE_BUCKET_NAME}
S3_ENDPOINT=${AWS_S3_ENDPOINT_URL}
S3_ALIAS_URL=https://atendimento.projetoravenna.cloud
S3_FORCE_PATH_STYLE=true
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
AWS_REGION=${AWS_S3_REGION_NAME}
AWS_S3_ENDPOINT=${AWS_S3_ENDPOINT_URL}
AWS_S3_FORCE_PATH_STYLE=true
DIRECT_UPLOADS_ENABLED=false
STORAGE_PROXY=true
ACTIVE_STORAGE_URL_STRATEGY=proxy

# Força o Rails a gerar links usando o domínio do túnel
RAILS_ASSET_HOST=https://atendimento.projetoravenna.cloud

# Aliases de compatibilidade
STORAGE_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
STORAGE_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
STORAGE_REGION=${AWS_S3_REGION_NAME}
STORAGE_ENDPOINT=${AWS_S3_ENDPOINT_URL}
STORAGE_BUCKET_NAME=${AWS_STORAGE_BUCKET_NAME}
STORAGE_FORCE_PATH_STYLE=true

# Webhooks e WebSocket
CABLE_URL=wss://atendimento.projetoravenna.cloud/cable
TRUSTED_PROXIES=0.0.0.0/0
CORS_ALLOWED_ORIGINS=*

# Security
FORCE_SSL=false

