# =============================================================================
# CHATWOOT — Arquivo de Variáveis de Ambiente
# =============================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: cp Chatwoot/.env.example Chatwoot/.env
#   2. Preencha TODOS os campos marcados com "CHANGE_ME"
#   3. Gere o SECRET_KEY_BASE com: openssl rand -hex 64
#   4. NUNCA commite o arquivo .env no repositório
# =============================================================================

# -----------------------------------------------------------------------------
# BANCO DE DADOS (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_HOST=chatwoot_db
POSTGRES_PORT=5432
POSTGRES_DB=chatwoot_production
POSTGRES_DATABASE=chatwoot_production
POSTGRES_USER=postgres
POSTGRES_USERNAME=postgres
# Deve ser igual ao POSTGRES_PASSWORD do .env raiz
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
# Deve usar a senha igual ao REDIS_PASSWORD do .env raiz
REDIS_URL=redis://:CHANGE_ME_strong_redis_password@chatwoot_redis:6379
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# -----------------------------------------------------------------------------
# RAILS / APLICAÇÃO
# -----------------------------------------------------------------------------
# Gere com: openssl rand -hex 64
SECRET_KEY_BASE=CHANGE_ME_openssl_rand_hex_64

# URL pública do Chatwoot (com https)
FRONTEND_URL=https://atendimento.SEU_DOMINIO.com

# -----------------------------------------------------------------------------
# ARMAZENAMENTO S3 (MinIO)
# Usamos dupla estratégia (AWS_* + STORAGE_*) para compatibilidade máxima.
# -----------------------------------------------------------------------------
ACTIVE_STORAGE_SERVICE=s3_compatible

# Bucket (deve ser igual ao S3_BUCKET no .env raiz)
S3_BUCKET_NAME=chatwoot

# Credenciais (devem ser iguais ao MINIO_ROOT_USER/PASSWORD no .env raiz)
AWS_ACCESS_KEY_ID=CHANGE_ME_minio_user
AWS_SECRET_ACCESS_KEY=CHANGE_ME_minio_password
AWS_REGION=us-east-1

# Endpoint público do MinIO (com https — o proxy reverso aponta para porta 9006)
AWS_S3_ENDPOINT=https://minio.SEU_DOMINIO.com
AWS_S3_FORCE_PATH_STYLE=true

# Aliases de compatibilidade (mesmos valores acima)
STORAGE_ACCESS_KEY_ID=CHANGE_ME_minio_user
STORAGE_SECRET_ACCESS_KEY=CHANGE_ME_minio_password
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=https://minio.SEU_DOMINIO.com
STORAGE_BUCKET_NAME=chatwoot
STORAGE_FORCE_PATH_STYLE=true

# -----------------------------------------------------------------------------
# SEGURANÇA
# -----------------------------------------------------------------------------
FORCE_SSL=true
