# =============================================================================
# AUTOMACAO-BACKBONE — Template de Variáveis de Ambiente (Abril 2026)
# =============================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha TODOS os campos marcados com "CHANGE_ME"
#   3. Gere os segredos com os comandos indicados em cada campo
#   4. NUNCA commite o arquivo .env no repositório (está no .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES GLOBAIS
# -----------------------------------------------------------------------------
TZ=America/Sao_Paulo
COMPOSE_PROJECT_NAME=automacao-backbone

# -----------------------------------------------------------------------------
# CREDENCIAIS COMPARTILHADAS — Gere com: openssl rand -hex 32
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_pass
REDIS_PASSWORD=CHANGE_ME_strong_redis_pass

# -----------------------------------------------------------------------------
# VERSÕES DAS IMAGENS (Estáveis Abril 2026)
# -----------------------------------------------------------------------------
CHATWOOT_IMAGE=chatwoot/chatwoot:v4.12.1
EVOLUTION_IMAGE=evoapicloud/evolution-api:v2.3.7
N8N_IMAGE=n8nio/n8n:2.16.0
MINIO_IMAGE=minio/minio:latest

# -----------------------------------------------------------------------------
# EVOLUTION API — Configurações de Conectividade
# -----------------------------------------------------------------------------
EVOLUTION_PORT=8081
SERVER_URL=https://evolution.seudominio.com

# Gere com: openssl rand -hex 32
AUTHENTICATION_API_KEY=CHANGE_ME_api_key
LANGUAGE=pt
TELEMETRY=false
RESTART_POLICY=always

# -----------------------------------------------------------------------------
# N8N — Configurações de Automação
# -----------------------------------------------------------------------------
# Gere com: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_encryption_key
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_n8n_pass

# -----------------------------------------------------------------------------
# MINIO (S3 Local Dedicado)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_pass
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=CHANGE_ME_minio_pass (mesma do root)
AWS_STORAGE_BUCKET_NAME=backbone-media
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_REGION_NAME=us-east-1
