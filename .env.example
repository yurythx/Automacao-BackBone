# =============================================================================
# AUTOMACAO-BACKBONE — Arquivo de Variáveis de Ambiente
# =============================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha TODOS os campos marcados com "CHANGE_ME"
#   3. Gere o SECRET_KEY_BASE com: openssl rand -hex 64
#   4. NUNCA commite o arquivo .env no repositório
# =============================================================================

# -----------------------------------------------------------------------------
# CREDENCIAIS COMPARTILHADAS
# -----------------------------------------------------------------------------
# Senha do PostgreSQL (usada por todos os serviços)
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password

# Senha do Redis (usada por todos os serviços)
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# Fuso horário do servidor
TZ=America/Sao_Paulo

# -----------------------------------------------------------------------------
# EVOLUTION API
# -----------------------------------------------------------------------------
EVOLUTION_IMAGE=evoapicloud/evolution-api:v2.3.7
EVOLUTION_CONTAINER=evolution_api
EVOLUTION_PORT=8081

# URL pública da Evolution API (com https)
SERVER_URL=https://evolution.SEU_DOMINIO.com

# Comportamento de instâncias
DEL_INSTANCE=false
DEL_TEMP_INSTANCES=false

# Provider (desativado por padrão)
PROVIDER_ENABLED=false
PROVIDER_HOST=127.0.0.1
PROVIDER_PORT=8080
PROVIDER_PREFIX=/

# Banco de dados da Evolution
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://postgres:CHANGE_ME_strong_postgres_password@postgres_evolution:5432/evolution_production
DATABASE_CONNECTION_CLIENT_NAME=evolution

# Autenticação da Evolution API — gere uma chave UUID forte:
# python3 -c "import uuid; print(uuid.uuid4())"
AUTHENTICATION_API_KEY=CHANGE_ME_uuid-api-key
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true

# Idioma e telemetria
LANGUAGE=pt
TELEMETRY=false

# Configuração de sessão WhatsApp (obrigatório para estabilidade do QR Code)
CONFIG_SESSION_PHONE_CLIENT=Chrome
CONFIG_SESSION_PHONE_NAME=Chrome
QRCODE_LIMIT=30

# Integrações
TYPEBOT_ENABLED=false
TYPEBOT_API_VERSION=latest
CHATWOOT_ENABLED=true
CHATWOOT_MESSAGE_READ=true
CHATWOOT_IMPORT_DATABASE_CONNECTION_URI=postgresql://postgres:CHANGE_ME_strong_postgres_password@postgres_evolution:5432/evolution_production
CHATWOOT_IMPORT_PLACEHOLDER_MEDIA_MESSAGE=true

# Cache Redis da Evolution
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://:CHANGE_ME_strong_redis_password@redis_evolution:6379
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=true
CACHE_LOCAL_ENABLED=false

# Política de restart
RESTART_POLICY=always

# -----------------------------------------------------------------------------
# N8N
# -----------------------------------------------------------------------------
# Chave de criptografia — gere com: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# Autenticação básica do n8n (configure na UI no primeiro acesso)
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_n8n_password

# -----------------------------------------------------------------------------
# MINIO (Object Storage Externo)
# ATENÇÃO: Esta stack utiliza o container 'backbone_minio' já existente no servidor.
# Credenciais devem coincidir com as do MinIO principal.
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=CHANGE_ME_minio_user
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
S3_BUCKET=chatwoot
