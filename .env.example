# =============================================================================
# AUTOMACAO-BACKBONE — Template COMPLETO de Variáveis de Ambiente (Abril 2026)
# =============================================================================

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES GLOBAIS
# -----------------------------------------------------------------------------
TZ=America/Sao_Paulo
COMPOSE_PROJECT_NAME=automacao-backbone

# Credenciais Compartilhadas (Mantenha o padrão forte)
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# -----------------------------------------------------------------------------
# VERSÕES DAS IMAGENS
# -----------------------------------------------------------------------------
CHATWOOT_IMAGE=chatwoot/chatwoot:v4.12.1
EVOLUTION_IMAGE=evoapicloud/evolution-api:v2.3.7
N8N_IMAGE=n8nio/n8n:2.16.0
MINIO_IMAGE=minio/minio:latest

# -----------------------------------------------------------------------------
# CHATWOOT — Atendimento Omnichannel
# -----------------------------------------------------------------------------
CHATWOOT_DOMAIN=atendimento.projetoravenna.cloud
SECRET_KEY_BASE=CHANGE_ME_openssl_rand_hex_64
FORCE_SSL=true

# -----------------------------------------------------------------------------
# EVOLUTION API — Gateway WhatsApp
# -----------------------------------------------------------------------------
EVOLUTION_CONTAINER=evolution_api
EVOLUTION_PORT=8081
SERVER_URL=https://evolution.projetoravenna.cloud
AUTHENTICATION_API_KEY=CHANGE_ME_API_KEY
RESTART_POLICY=always

# Comportamento de Mensagens & Instâncias
LANGUAGE=pt
TELEMETRY=false
DEL_INSTANCE=false
DEL_TEMP_INSTANCES=false
CHATWOOT_ENABLED=true
CHATWOOT_MESSAGE_READ=true
CHATWOOT_IMPORT_PLACEHOLDER_MEDIA_MESSAGE=true
CONFIG_SESSION_PHONE_CLIENT=Chrome
CONFIG_SESSION_PHONE_NAME=Chrome
QRCODE_LIMIT=30
TYPEBOT_ENABLED=false
TYPEBOT_API_VERSION=latest

# Instâncias Databases (Comunicação Interna)
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://postgres:${POSTGRES_PASSWORD}@postgres_evolution:5432/evolution_production
DATABASE_CONNECTION_CLIENT_NAME=evolution

# Cache Redis
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://:${REDIS_PASSWORD}@redis_evolution:6379
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=true
CACHE_LOCAL_ENABLED=false

# -----------------------------------------------------------------------------
# N8N — Automação de Fluxos
# -----------------------------------------------------------------------------
N8N_DOMAIN=n8n.projetoravenna.cloud
N8N_ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_N8N_PASSWORD

# -----------------------------------------------------------------------------
# STORAGE S3 (MinIO Local Dedicado)
# -----------------------------------------------------------------------------
MINIO_DOMAIN=minio.projetoravenna.cloud
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# Configurações de Acesso S3
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=CHANGE_ME_MINIO_PASSWORD
AWS_STORAGE_BUCKET_NAME=backbone-media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=http://minio:9000


